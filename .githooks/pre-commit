#!/bin/bash

echo "🔐 NanoBot Firewall v3.3 (NODE + SHARED ISOLATION)"

# ----------------------------
# LOAD NODE IDENTITY
# ----------------------------
IDENTITY_FILE=".node_identity"

if [ ! -f "$IDENTITY_FILE" ]; then
  echo "❌ BLOCKED: Missing .node_identity"
  exit 1
fi

ROLE=$(grep "^ROLE=" "$IDENTITY_FILE" | cut -d= -f2)
NODE=$(grep "^NODE=" "$IDENTITY_FILE" | cut -d= -f2)

if [ -z "$ROLE" ] || [ -z "$NODE" ]; then
  echo "❌ BLOCKED: Invalid .node_identity"
  exit 1
fi

echo "✔ Node detected: $NODE ($ROLE)"

# ----------------------------
# GET STAGED FILES
# ----------------------------
FILES=$(git diff --cached --name-only)

if [ -z "$FILES" ]; then
  echo "✔ No staged changes"
  exit 0
fi

# ----------------------------
# GLOBAL ALLOWLIST (system files)
# ----------------------------
GLOBAL_ALLOWED=(
  "README.md"
  ".gitignore"
  ".githooks"
  "LOCK_SYNC.md"
  "bootstrap.sh"
  "CHANGELOG.md"
  ".node_identity"
)

is_global_allowed() {
  for g in "${GLOBAL_ALLOWED[@]}"; do
    if [[ "$1" == "$g" || "$1" == "$g/"* ]]; then
      return 0
    fi
  done
  return 1
}

# ----------------------------
# ENFORCEMENT RULES
# ----------------------------
for f in $FILES; do

  # allow system files
  if is_global_allowed "$f"; then
    continue
  fi

  # allow node-owned folder
  if [[ "$f" == nodes/$NODE/* ]]; then
    continue
  fi

  # allow shared workspace (IMPORTANT FIX)
  if [[ "$f" == nodes/shared/* ]]; then
    continue
  fi

  echo "❌ BLOCKED: Node '$NODE' cannot modify: $f"
  exit 1

done

echo "✅ NanoBot commit approved"
exit 0
