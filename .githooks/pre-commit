#!/bin/bash

echo "🔐 NanoBot v6 Runtime Node Engine"

# -----------------------------
# AUTO-DETECT NODE (TRUTH SOURCE)
# -----------------------------

HOST=$(hostname)

ROLE="unknown"
NODE="$HOST"

# Default role inference from hostname
case "$HOST" in
    *pi*)
        ROLE="pi"
        ;;
    *orin*)
        ROLE="orin"
        ;;
    *idea*|*lenovo*|*nano*|*controller*)
        ROLE="controller"
        ;;
esac

# -----------------------------
# OPTIONAL OVERRIDE FILE
# -----------------------------
if [ -f ".node_identity" ]; then
    FILE_ROLE=$(grep "^ROLE=" .node_identity | cut -d= -f2)
    FILE_NODE=$(grep "^NODE=" .node_identity | cut -d= -f2)

    # only allow override if consistent (prevents spoofing)
    if [[ "$FILE_ROLE" == "$ROLE" || "$FILE_ROLE" == "controller" ]]; then
        ROLE="$FILE_ROLE"
        NODE="$FILE_NODE"
    fi
fi

echo "✔ Detected Node: $NODE"
echo "✔ Role: $ROLE"

# -----------------------------
# GET STAGED FILES
# -----------------------------
FILES=$(git diff --cached --name-only)

if [ -z "$FILES" ]; then
    echo "✔ No staged changes"
    exit 0
fi

# -----------------------------
# RULE ENGINE
# -----------------------------
for file in $FILES; do

    # system allowlist
    case "$file" in
        README.md|.gitignore|LOCK_SYNC.md|.githooks/*|bootstrap.sh|nodes/NODE_SPEC.md)
            continue
        ;;
    esac

    # shared rules (strict)
    if [[ "$file" == nodes/shared/* ]]; then
        if [[ "$file" == *.txt || "$file" == *test* ]]; then
            echo "❌ BLOCKED: Invalid shared artifact: $file"
            exit 1
        fi
        continue
    fi

    # PI rules
    if [[ "$ROLE" == "pi" ]]; then
        if [[ "$file" != nodes/pi/* && "$file" != nodes/shared/* ]]; then
            echo "❌ BLOCKED: Pi cannot modify $file"
            exit 1
        fi
    fi

    # ORIN rules
    if [[ "$ROLE" == "orin" ]]; then
        if [[ "$file" != nodes/orin/* && "$file" != nodes/shared/* ]]; then
            echo "❌ BLOCKED: Orin cannot modify $file"
            exit 1
        fi
    fi

    # CONTROLLER rules
    if [[ "$ROLE" == "controller" ]]; then
        if [[ "$file" == nodes/pi/runtime/* || "$file" == nodes/orin/runtime/* ]]; then
            echo "❌ BLOCKED: Controller cannot modify runtime state"
            exit 1
        fi
    fi

done

# -----------------------------
# DRIFT CHECK (optional warning only)
# -----------------------------
git fetch origin -q

LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/main)

if [ "$LOCAL" != "$REMOTE" ]; then
    echo "⚠ WARNING: Node is not synced with origin/main"
fi

echo "✅ NanoBot v6 commit approved"
exit 0
