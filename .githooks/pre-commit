#!/bin/bash

echo "🔐 NanoBot v7 Runtime Firewall"

# -----------------------------
# LOAD NODE FROM EXTERNAL SOURCE
# -----------------------------
if [ -f ~/.nanobot_identity ]; then
    NODE=$(cat ~/.nanobot_identity | cut -d= -f2)
else
    echo "❌ Missing runtime identity"
    exit 1
fi

# -----------------------------
# LOAD REGISTRY (AUTHORITATIVE)
# -----------------------------
REGISTRY="nodes/NODE_REGISTRY.json"

if [ ! -f "$REGISTRY" ]; then
    echo "❌ Missing node registry"
    exit 1
fi

ROLE=$(grep -A2 "\"$NODE\"" $REGISTRY | grep "role" | cut -d: -f2 | tr -d ' ",')
TRUST=$(grep -A3 "\"$NODE\"" $REGISTRY | grep "trust" | cut -d: -f2 | tr -d ' ",}')

echo "✔ Node: $NODE"
echo "✔ Role: $ROLE"
echo "✔ Trust: $TRUST"

# -----------------------------
# ONLY STAGED FILES
# -----------------------------
FILES=$(git diff --cached --name-only)

if [ -z "$FILES" ]; then
    echo "✔ No staged changes"
    exit 0
fi

# -----------------------------
# RULE ENGINE v7
# -----------------------------
for file in $FILES; do

    case "$file" in
        README.md|.gitignore|LOCK_SYNC.md|.githooks/*|bootstrap.sh|nodes/NODE_REGISTRY.json)
            continue
        ;;
    esac

    # controller can do anything EXCEPT runtime pollution
    if [[ "$ROLE" == "controller" ]]; then
        if [[ "$file" == nodes/*runtime* ]]; then
            echo "❌ BLOCKED: Controller cannot modify runtime layer"
            exit 1
        fi
    fi

    # execution nodes strictly isolated
    if [[ "$ROLE" == "pi" ]]; then
        if [[ "$file" != nodes/pi/* && "$file" != nodes/shared/* ]]; then
            echo "❌ BLOCKED: Pi violation $file"
            exit 1
        fi
    fi

    if [[ "$ROLE" == "orin" ]]; then
        if [[ "$file" != nodes/orin/* && "$file" != nodes/shared/* ]]; then
            echo "❌ BLOCKED: Orin violation $file"
            exit 1
        fi
    fi

done

echo "✅ NanoBot v7 commit approved"
exit 0
